{
  "name": "keywords-for-authors",
  "private": true,
  "version": "0.0.0",
  "description": "Credit-based keyword-research web app for Amazon KDP authors",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:web": "npm run dev --workspace @kfa/web",
    "dev:api": "npm run dev --workspace @kfa/api",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "db:generate": "npm run db:generate --workspace @kfa/api",
    "datavet": "node datavet/server.mjs"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
