# apps/web public config — Vite inlines any VITE_-prefixed var into the client
# bundle, so ONLY put publishable/public values here (never secrets).
# Copy to `.env` (gitignored) and fill in.

# Leave blank in dev (Vite proxies /api to the local Worker). Set to the
# deployed Worker URL in production.
VITE_API_URL=""

# Clerk publishable key (starts with pk_ — safe to ship to the browser).
#
# Set this PER MODE so localhost uses the Clerk *dev* instance and the deployed
# build uses the *prod* instance (a pk_live key is domain-locked and won't
# initialize on localhost — sign-in buttons silently fail to render):
#   .env.development → pk_test…   (used by `npm run dev:web`)
#   .env.production  → pk_live…   (used by `npm run build` / deploy)
# `clerk env pull --instance dev` writes the dev key (and a secret — keep only
# the VITE_CLERK_PUBLISHABLE_KEY line here; the secret belongs to the Worker).
VITE_CLERK_PUBLISHABLE_KEY=""
