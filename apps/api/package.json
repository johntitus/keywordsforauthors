    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "drizzle-kit": "^0.30.1",
    "typescript": "^5.7.3",
    "wrangler": "^3.99.0"
  }
