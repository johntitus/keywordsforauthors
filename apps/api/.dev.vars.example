# apps/api local secrets — Wrangler loads this file for `wrangler dev`.
# Copy to `.dev.vars` (gitignored) and fill in. In production set these with
# `wrangler secret put NAME` instead.

# DataForSEO (HTTP basic auth login/password from your dashboard)
DATAFORSEO_LOGIN=""
DATAFORSEO_PASSWORD=""

# Clerk — the Worker verifies session JWTs with @hono/clerk-auth, which needs
# BOTH the secret key (sk_) and the publishable key (pk_, same value the SPA uses).
CLERK_SECRET_KEY=""
CLERK_PUBLISHABLE_KEY=""
# Svix signing secret for the /api/webhooks/clerk endpoint (whsec_). Optional
# until the user.created webhook is wired.
CLERK_WEBHOOK_SECRET=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Resend (transactional email)
RESEND_API_KEY=""
